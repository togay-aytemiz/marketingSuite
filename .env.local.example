# Copy this file to .env.local and fill the values you need.

PORT=3000

# Optional at first. Leave empty until you are ready to enable AI generation.
GEMINI_API_KEY=""

# Required for Sanity fetch and publish.
SANITY_PROJECT_ID=""
SANITY_DATASET="production"
SANITY_TOKEN=""

# Supported aliases for the same Sanity token.
SANITY_API_TOKEN=""
SANITY_API_KEY=""
SANITY_API_VERSION="2026-03-01"

# Optional. Enables automatic blog artifact refresh in your local Qualy site
# after a successful publish from Marketing Suite.
QUALY_LP_PATH="/Users/togay/Desktop/Qualy-lp"

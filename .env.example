# Copy this file to .env.local for local development.

PORT=3000

# Optional at first. Add this when you want AI generation to work.
OPENAI_API_KEY=""
GEMINI_API_KEY=""

# Required for Sanity fetch and publish.
SANITY_PROJECT_ID=""
SANITY_DATASET="production"
SANITY_TOKEN=""

# Supported aliases for the same Sanity secret.
SANITY_API_TOKEN=""
SANITY_API_KEY=""
SANITY_API_VERSION="2026-03-01"

# Optional. If set, successful Sanity publish also runs:
# npm --prefix "$QUALY_LP_PATH" run blog:generate
QUALY_LP_PATH="/Users/togay/Desktop/Qualy-lp"
